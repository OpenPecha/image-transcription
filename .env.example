# Backend API base URL (no trailing slash required)
VITE_BASE_URL=http://localhost:8000

# Auth0 — leave blank to use dev auth mock locally
VITE_AUTH0_DOMAIN=
VITE_AUTH0_CLIENT_ID=
VITE_AUTH0_AUDIENCE=
VITE_AUTH0_REDIRECT_URI=

# Set to "true" to always skip Auth0 and use the dev auth mock
VITE_DEV_AUTH=
